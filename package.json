{
  "name": "mia-survey-angular",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build2": "ng build --configuration production --project=@doroteati/mia-survey-core && cd dist/doroteati/mia-survey-core/ && npm publish --access public",
    "build3": "ng build --configuration production --project=@doroteati/mia-survey-panel && cd dist/doroteati/mia-survey-panel/ && npm publish --access public",
    "build4": "ng build --configuration production --project=@doroteati/mia-survey-viewer && cd dist/doroteati/mia-survey-viewer/ && npm publish --access public",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.0.0",
    "@angular/cdk": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/material": "^21.0.0",
    "@angular/material-moment-adapter": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-browser-dynamic": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@doroteati/mia-auth": "^21.0.1",
    "@doroteati/mia-core": "^21.0.0",
    "@doroteati/mia-form": "^21.0.3",
    "@doroteati/mia-layout": "^21.1.0",
    "@doroteati/mia-loading": "^21.0.0",
    "@doroteati/mia-table": "^21.1.0",
    "@ngx-pwa/local-storage": "^21.0.0",
    "dayjs": "^1.11.13",
    "moment": "^2.30.1",
    "ngx-currency": "^19.0.0",
    "ngx-quill": "^26.0.0",
    "parchment": "^3.0.0",
    "quill": "^2.0.3",
    "rxjs": "~7.8.0",
    "tslib": "^2.6.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.4.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^21.0.0",
    "typescript": "~5.9.0"
  }
